<Window
	x:Class="XenoUI.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:XenoUI" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
	ResizeMode="NoResize"
	Title="Xeno"
	Height="400"
	Width="700"
	WindowStyle="None"
	MouseLeftButtonDown="Window_MouseLeftButtonDown">
	<WindowChrome.WindowChrome>
		<WindowChrome
			GlassFrameThickness="0"
			CornerRadius="15"
			CaptionHeight="0" />
	</WindowChrome.WindowChrome>
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style
				TargetType="{x:Type Button}"
				x:Key="TitleBarButtonStyle">
				<Setter
					Property="UIElement.RenderTransformOrigin"
					Value="0.5,0.5" />
				<Setter
					Property="RenderTransform">
					<Setter.Value>
						<ScaleTransform
							ScaleX="1"
							ScaleY="1" />
					</Setter.Value>
				</Setter>
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="bdr_main"
								BorderThickness="1"
								BorderBrush="#00FFFFFF"
								Background="#00FFFFFF">
								<ContentPresenter
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									ContentSource="Content" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="bdr_main"
										Property="Background"
										Value="#474747" />
									<TriggerBase.EnterActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleX"
													To="1.15"
													Duration="0:0:0.2" />
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleY"
													To="1.15"
													Duration="0:0:0.2" />
											</Storyboard>
										</BeginStoryboard>
									</TriggerBase.EnterActions>
									<TriggerBase.ExitActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleX"
													To="1"
													Duration="0:0:0.2" />
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleY"
													To="1"
													Duration="0:0:0.2" />
											</Storyboard>
										</BeginStoryboard>
									</TriggerBase.ExitActions>
								</Trigger>
								<Trigger
									Property="IsPressed"
									Value="True">
									<Setter
										TargetName="bdr_main"
										Property="Background"
										Value="#474747" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				TargetType="{x:Type TabItem}"
				x:Key="AddTabButtonStyle">
				<Setter
					Property="Padding"
					Value="0" />
				<Setter
					Property="Width"
					Value="30" />
				<Setter
					Property="Height"
					Value="30" />
				<Setter
					Property="HorizontalContentAlignment"
					Value="Center" />
				<Setter
					Property="VerticalContentAlignment"
					Value="Center" />
				<Setter
					Property="Background"
					Value="#FF090909" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type TabItem}">
							<Grid
								Background="{TemplateBinding Background}">
								<Image
									Source="/Resources/Images/add.png"
									Width="16"
									Height="16"
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Grid>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										Property="Background"
										Value="#474747" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				TargetType="{x:Type TabItem}"
				x:Key="{x:Type TabItem}">
				<Setter
					Property="Background"
					Value="#FF000000" />
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="Margin"
					Value="0,5,-8,5" />
				<Setter
					Property="Padding"
					Value="10,2" />
				<Setter
					Property="BorderBrush"
					Value="#00FFFFFF" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type TabItem}">
							<Border
								Background="{TemplateBinding Background}"
								BorderBrush="#00FFFFFF"
								CornerRadius="2"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									ContentSource="Header" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										Property="Foreground"
										Value="#FFADD8E6" />
								</Trigger>
								<Trigger
									Property="TabItem.IsSelected"
									Value="True">
									<Setter
										Property="Foreground"
										Value="#FF90EE90" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				TargetType="{x:Type TextBox}"
				x:Key="{x:Type TextBox}">
				<Setter
					Property="Background"
					Value="#FF1E1E1E" />
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="BorderBrush"
					Value="#373737" />
				<Setter
					Property="BorderThickness"
					Value="1" />
			</Style>
			<Style
				TargetType="{x:Type Image}"
				x:Key="IconScaleUpStyle">
				<Setter
					Property="UIElement.RenderTransformOrigin"
					Value="0.5,0.5" />
				<Setter
					Property="RenderTransform">
					<Setter.Value>
						<ScaleTransform
							ScaleX="0.1"
							ScaleY="0.1" />
					</Setter.Value>
				</Setter>
				<Style.Triggers>
					<EventTrigger
						RoutedEvent="Image.Loaded">
						<BeginStoryboard>
							<Storyboard>
								<DoubleAnimation
									Storyboard.TargetProperty="RenderTransform.ScaleX"
									To="1"
									Duration="0:0:0.25">
									<DoubleAnimation.EasingFunction>
										<CubicEase
											EasingMode="EaseInOut" />
									</DoubleAnimation.EasingFunction>
								</DoubleAnimation>
								<DoubleAnimation
									Storyboard.TargetProperty="RenderTransform.ScaleY"
									To="1"
									Duration="0:0:0.25">
									<DoubleAnimation.EasingFunction>
										<CubicEase
											EasingMode="EaseInOut" />
									</DoubleAnimation.EasingFunction>
								</DoubleAnimation>
							</Storyboard>
						</BeginStoryboard>
					</EventTrigger>
				</Style.Triggers>
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Control.Background>
		<LinearGradientBrush
			EndPoint="0.5,1"
			StartPoint="0.5,0">
			<GradientStop
				Color="Black" />
			<GradientStop
				Color="#050505"
				Offset="0.65" />
		</LinearGradientBrush>
	</Control.Background>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="40" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Grid>
			<WrapPanel>
				<Image
					Source="/Resources/Images/icon.ico"
					Margin="10,0,0,0" />
				<TextBlock
					FontSize="18"
					Margin="10,0,0,0"
					VerticalAlignment="Center"
					FontFamily="Segoe UI Black"
					ToolTip="Made by .rizve on Discord, https://xeno.onl">
					<TextBlock.Foreground>
						<LinearGradientBrush
							EndPoint="0.5,1"
							StartPoint="0.5,0">
							<GradientStop
								Color="#FFA2A1A1"
								Offset="0.149" />
							<GradientStop
								Color="White"
								Offset="0.4" />
						</LinearGradientBrush>
					</TextBlock.Foreground>Xeno</TextBlock>
				<TextBlock
					Margin="3,0,0,0"
					VerticalAlignment="Center"
					FontFamily="Segoe UI Semibold">
					<TextBlock.Foreground>
						<LinearGradientBrush
							EndPoint="0.5,1"
							StartPoint="0.5,0">
							<GradientStop
								Color="#FF5894F5"
								Offset="0.25" />
							<GradientStop
								Color="#FF3F6AB1"
								Offset="1" />
						</LinearGradientBrush>
					</TextBlock.Foreground>v1.3.25b</TextBlock>
				<TextBlock
					Margin="4,0,0,0"
					FontSize="10"
					VerticalAlignment="Center"
					FontFamily="Consolas"
					Width="89">
					<TextBlock.Foreground>
						<LinearGradientBrush
							EndPoint="0.5,1"
							StartPoint="0.5,0">
							<GradientStop
								Color="#FF989898"
								Offset="0.145" />
							<GradientStop
								Color="White"
								Offset="0.55" />
						</LinearGradientBrush>
					</TextBlock.Foreground>
					<Run
						Text="https://xeno.onl" />
				</TextBlock>
			</WrapPanel>
			<StackPanel
				Orientation="Horizontal"
				HorizontalAlignment="Right">
				<Button
					Name="buttonMinimize"
					Style="{StaticResource TitleBarButtonStyle}"
					Width="30"
					Background="#00FFFFFF"
					BorderBrush="#00FFFFFF"
					Margin="0,0,10,0"
					Click="buttonMinimize_Click">
					<Image
						Source="/Resources/Images/minimize.png"
						Width="20"
						Height="20" />
				</Button>
				<Button
					Name="buttonMaximize"
					Style="{StaticResource TitleBarButtonStyle}"
					Width="30"
					Background="#00FFFFFF"
					BorderBrush="#00FFFFFF"
					Margin="0,0,10,0"
					Click="buttonMaximize_Click">
					<Image
						Name="maximizeImage"
						Source="/Resources/Images/maximize.png"
						Width="20"
						Height="20" />
				</Button>
				<Button
					Name="buttonClose"
					Style="{StaticResource TitleBarButtonStyle}"
					Width="30"
					Background="#00FFFFFF"
					BorderBrush="#00FFFFFF"
					Margin="0,0,10,0"
					Click="buttonClose_Click">
					<Image
						Source="/Resources/Images/close.png"
						Width="20"
						Height="20" />
				</Button>
			</StackPanel>
		</Grid>
		<Border
			Margin="0,35,0,0"
			Background="#FF808080"
			Height="1" />
		<Grid
			Row="1"
			Margin="10,4,10,0">
			<TabControl
				Name="tabControlScripts"
				Background="#00FFFFFF"
				BorderThickness="0">
				<TabItem
					Name="buttonAddTab"
					Style="{StaticResource AddTabButtonStyle}"
					PreviewMouseDown="buttonAddTab_Click" />
			</TabControl>
		</Grid>
		<wv2:WebView2
			Name="WebView2Client"
			Grid.Row="1"
			Margin="10,35,10,40"
			DefaultBackgroundColor="Black" />
		<Button
			Name="buttonExecute"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="660,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Click="buttonExecute_Click">
			<Image
				Style="{StaticResource IconScaleUpStyle}"
				Source="/Resources/Images/execute.png"
				Width="25"
				Height="25"
				ToolTip="Execute" />
		</Button>
		<Button
			Name="buttonShowMultinstance"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="625,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Click="buttonShowMultinstance_Click">
			<Grid>
				<Image
					Style="{StaticResource IconScaleUpStyle}"
					Source="/Resources/Images/multiple.png"
					Width="25"
					Height="25"
					ToolTip="Clients Management" />
				<Ellipse
					Name="ClientStatusIndicator"
					Width="10"
					Height="10"
					HorizontalAlignment="Left"
					VerticalAlignment="Top"
					Margin="-4,-5"
					Fill="#FFF5F5DC"
					Stroke="#FF000000"
					StrokeThickness="0"
					ToolTip="Clients Overall Status" />
			</Grid>
		</Button>
		<Button
			Name="buttonShowScripts"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="590,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Visibility="Visible"
			Click="buttonShowScripts_Click">
			<Image
				Style="{StaticResource IconScaleUpStyle}"
				Source="/Resources/Images/scripts.png"
				Width="30"
				Height="30"
				ToolTip="View Scripts" />
		</Button>
		<Button
			Name="buttonAttach"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="555,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Visibility="Visible"
			Click="buttonAttach_Click">
			<Image
				Style="{StaticResource IconScaleUpStyle}"
				Source="/Resources/Images/attach.png"
				Width="25"
				Height="30"
				ToolTip="Attach" />
		</Button>
		<Button
			Name="buttonClear"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="115,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Click="buttonClear_Click">
			<Image
				Style="{StaticResource IconScaleUpStyle}"
				Source="/Resources/Images/clear.png"
				Width="30"
				Height="30"
				ToolTip="Clear" />
		</Button>
		<Button
			Name="buttonSaveFile"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="80,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Click="buttonSaveFile_Click">
			<Image
				Style="{StaticResource IconScaleUpStyle}"
				Source="/Resources/Images/save.png"
				Width="25"
				Height="25"
				ToolTip="Save" />
		</Button>
		<Button
			Name="buttonOpenFile"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="45,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Click="buttonOpenFile_Click">
			<Image
				Style="{StaticResource IconScaleUpStyle}"
				Source="/Resources/Images/open.png"
				Width="25"
				Height="25"
				ToolTip="Open" />
		</Button>
		<Button
			Name="buttonOpenSettings"
			Style="{StaticResource TitleBarButtonStyle}"
			HorizontalAlignment="Left"
			Height="30"
			Margin="10,325,0,0"
			Grid.Row="1"
			VerticalAlignment="Top"
			Width="30"
			Background="#00FFFFFF"
			BorderBrush="#00FFFFFF"
			Cursor="Hand"
			Click="buttonShowSettings_Click">
			<Image
				Style="{StaticResource IconScaleUpStyle}"
				Source="/Resources/Images/settings.png"
				Width="25"
				Height="25"
				ToolTip="Settings" />
		</Button>
	</Grid>
</Window>
