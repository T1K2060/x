<Window
	x:Class="XenoUI.SettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Settings Window"
	Height="200"
	Width="300"
	WindowStyle="None"
	ResizeMode="NoResize"
	Background="#00FFFFFF"
	AllowsTransparency="True"
	WindowStartupLocation="CenterOwner"
	ShowInTaskbar="False"
	Topmost="True" xmlns:xenoui="clr-namespace:XenoUI">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style
				TargetType="{x:Type Button}"
				x:Key="TitleBarButtonStyle">
				<Setter
					Property="UIElement.RenderTransformOrigin"
					Value="0.5,0.5" />
				<Setter
					Property="RenderTransform">
					<Setter.Value>
						<ScaleTransform
							ScaleX="1"
							ScaleY="1" />
					</Setter.Value>
				</Setter>
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="bdr_main"
								BorderThickness="1"
								BorderBrush="#00FFFFFF"
								Background="#00FFFFFF">
								<ContentPresenter
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									ContentSource="Content" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="bdr_main"
										Property="Background"
										Value="#474747" />
									<TriggerBase.EnterActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleX"
													To="1.15"
													Duration="0:0:0.2" />
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleY"
													To="1.15"
													Duration="0:0:0.2" />
											</Storyboard>
										</BeginStoryboard>
									</TriggerBase.EnterActions>
									<TriggerBase.ExitActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleX"
													To="1"
													Duration="0:0:0.2" />
												<DoubleAnimation
													Storyboard.TargetProperty="RenderTransform.ScaleY"
													To="1"
													Duration="0:0:0.2" />
											</Storyboard>
										</BeginStoryboard>
									</TriggerBase.ExitActions>
								</Trigger>
								<Trigger
									Property="IsPressed"
									Value="True">
									<Setter
										TargetName="bdr_main"
										Property="Background"
										Value="#474747" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				TargetType="{x:Type ScrollViewer}"
				x:Key="CustomScrollViewerStyle">
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type ScrollViewer}">
							<Grid>
								<ScrollContentPresenter
									Margin="0" />
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				TargetType="{x:Type Button}"
				x:Key="DarkRoundedButtonStyle">
				<Setter
					Property="Background"
					Value="#1A1A1A" />
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="BorderBrush"
					Value="#333333" />
				<Setter
					Property="BorderThickness"
					Value="1" />
				<Setter
					Property="Padding"
					Value="5,2" />
				<Setter
					Property="FontFamily"
					Value="Consolas" />
				<Setter
					Property="FontSize"
					Value="14" />
				<Setter
					Property="FrameworkElement.Cursor"
					Value="Hand" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="border"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="4"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="border"
										Property="Background"
										Value="#2E2E2E" />
								</Trigger>
								<Trigger
									Property="IsPressed"
									Value="True">
									<Setter
										TargetName="border"
										Property="Background"
										Value="#3F3F3F" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				TargetType="{x:Type CheckBox}"
				x:Key="{x:Type CheckBox}">
				<Setter
					Property="Background"
					Value="#FFFFFFFF" />
				<Setter
					Property="BorderBrush"
					Value="#FF262E34" />
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="BorderThickness"
					Value="1" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type CheckBox}">
							<StackPanel
								Orientation="Horizontal"
								HorizontalAlignment="Stretch">
								<Border
									BorderBrush="{TemplateBinding BorderBrush}"
									Background="{TemplateBinding Background}"
									BorderThickness="{TemplateBinding BorderThickness}"
									Width="15"
									Height="15">
									<Grid>
										<Grid
											Name="nullBlock"
											Background="{TemplateBinding Foreground}"
											Margin="1"
											Visibility="Collapsed" />
										<Path
											Name="eliCheck"
											Stretch="Uniform"
											Width="15"
											Height="10"
											Fill="{TemplateBinding Foreground}"
											Data="F1 M9.97498,1.22334 L4.6983,9.09834 L4.52164,9.09834 L0,5.19331 L1.27664,3.52165 L4.255,6.08833 L8.33331,1.52588E-05 L9.97498,1.22334"
											Visibility="Collapsed" />
									</Grid>
								</Border>
								<TextBlock
									Margin="5,0,0,0"
									VerticalAlignment="Center"
									Foreground="#FFFFFFFF"
									Text="{TemplateBinding Content}" />
							</StackPanel>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										Property="Background"
										Value="#FFD3D3D3" />
								</Trigger>
								<Trigger
									Property="IsPressed"
									Value="True">
									<Setter
										Property="Background"
										Value="#FF9C9E9F" />
								</Trigger>
								<Trigger
									Property="IsEnabled"
									Value="False">
									<Setter
										Property="Background"
										Value="#FFD3D3D3" />
									<Setter
										Property="Foreground"
										Value="#FF808080" />
									<Setter
										Property="BorderBrush"
										Value="#FF808080" />
									<Setter
										TargetName="eliCheck"
										Property="UIElement.Opacity"
										Value="0.5" />
								</Trigger>
								<Trigger
									Property="ToggleButton.IsChecked"
									Value="True">
									<Setter
										TargetName="eliCheck"
										Property="Visibility"
										Value="Visible" />
								</Trigger>
								<Trigger
									Property="ToggleButton.IsChecked"
									Value="{x:Null}">
									<Setter
										TargetName="nullBlock"
										Property="Visibility"
										Value="Visible" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				TargetType="{x:Type TextBox}"
				x:Key="{x:Type TextBox}">
				<Setter
					Property="Background"
					Value="#FF1E1E1E" />
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="BorderBrush"
					Value="#373737" />
				<Setter
					Property="BorderThickness"
					Value="1" />
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Border
		CornerRadius="10"
		BorderBrush="#FF000000"
		BorderThickness="2"
		Padding="6">
		<Border.Background>
			<LinearGradientBrush
				EndPoint="0.5,1"
				StartPoint="0.5,0">
				<GradientStop
					Color="Black" />
				<GradientStop
					Color="#FF03000f"
					Offset="0.64" />
			</LinearGradientBrush>
		</Border.Background>
		<Grid>
			<Grid
				VerticalAlignment="Top"
				Height="20"
				HorizontalAlignment="Right"
				Width="75"
				Margin="0,5,5,0">
				<Button
					Name="buttonClose"
					Style="{StaticResource TitleBarButtonStyle}"
					Width="25"
					Background="#00FFFFFF"
					BorderBrush="#00FFFFFF"
					Margin="50,-10,0,0"
					Click="buttonClose_Click">
					<Image
						Source="/Resources/Images/close2.png"
						Width="20"
						Height="20"
						Margin="0,-1,0,0" />
				</Button>
				<TextBlock
					FontSize="18"
					Margin="-330,-11,0,0"
					VerticalAlignment="Center"
					FontFamily="Consolas"
					Width="150">
					<TextBlock.Foreground>
						<LinearGradientBrush
							EndPoint="0.5,1"
							StartPoint="0.5,0">
							<GradientStop
								Color="#FF737373" />
							<GradientStop
								Color="White"
								Offset="0.45" />
						</LinearGradientBrush>
					</TextBlock.Foreground>Settings</TextBlock>
			</Grid>
			<Border
				Margin="0,-135,0,0"
				Background="#FF808080"
				Height="1" />
			<ScrollViewer
				VerticalScrollBarVisibility="Auto"
				HorizontalScrollBarVisibility="Disabled"
				Margin="5,30,5,5"
				Style="{StaticResource CustomScrollViewerStyle}">
				<StackPanel>
					<CheckBox
						Name="CheckBoxAutoAttach"
						Content="Auto Attach"
						Foreground="#FFFFFFFF"
						FontFamily="Franklin Gothic Medium"
						Background="#FF000000"
						FontSize="14"
						Margin="0,0,0,5"
						Checked="CheckBoxSettings_Checked"
						Unchecked="CheckBoxSettings_Checked" />
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<CheckBox
						Name="CheckBoxRedirectErrors"
						Content="Redirect Errors"
						Foreground="#FFFFFFFF"
						FontFamily="Franklin Gothic Medium"
						Background="#FF000000"
						FontSize="14"
						Margin="0,0,0,5"
						Checked="CheckBoxRedirErr_Checked"
						Unchecked="CheckBoxRedirErr_Checked" />
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<CheckBox
						Name="CheckBoxRedirectOutput"
						Content="Redirect Output"
						Foreground="#FFFFFFFF"
						FontFamily="Franklin Gothic Medium"
						Background="#FF000000"
						FontSize="14"
						Margin="0,0,0,5"
						Checked="CheckBoxRedirOutput_Checked"
						Unchecked="CheckBoxRedirOutput_Checked" />
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<CheckBox
						Name="CheckBoxUseConsole"
						Content="Show Debug Console"
						Foreground="#FFFFFFFF"
						FontFamily="Franklin Gothic Medium"
						Background="#FF000000"
						FontSize="14"
						Margin="0,0,0,5"
						Checked="CheckBoxUseConsole_Checked"
						Unchecked="CheckBoxUseConsole_Checked" />
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<CheckBox
						Name="CheckBoxDiscordRPC"
						Content="Discord RPC"
						Foreground="#FFFFFFFF"
						FontFamily="Franklin Gothic Medium"
						Background="#FF000000"
						FontSize="14"
						Margin="0,0,0,5"
						Checked="CheckBoxDiscordRPC_Checked"
						Unchecked="CheckBoxDiscordRPC_Checked" />
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<CheckBox
						Name="CheckBoxTopMost"
						Content="Top Most"
						Foreground="#FFFFFFFF"
						FontFamily="Franklin Gothic Medium"
						Background="#FF000000"
						FontSize="14"
						Margin="0,0,0,5"
						Checked="CheckBoxTopMost_Checked"
						Unchecked="CheckBoxTopMost_Checked" />
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<Button
						Name="buttonRestart"
						Style="{StaticResource DarkRoundedButtonStyle}"
						Content="Restart"
						Width="105"
						Height="20"
						Margin="-170,0,0,5"
						BorderBrush="#FF333333"
						Click="buttonRestart_Click">
						<Control.Background>
							<LinearGradientBrush
								EndPoint="0.5,1"
								StartPoint="0.5,0">
								<GradientStop
									Color="Black" />
								<GradientStop
									Color="#FF1A1A1A"
									Offset="1" />
							</LinearGradientBrush>
						</Control.Background>
					</Button>
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<Button
						Name="buttonResetTabs"
						Style="{StaticResource DarkRoundedButtonStyle}"
						Content="Reset Tabs"
						Width="105"
						Height="20"
						Margin="-170,0,0,5"
						Click="buttonResetTabs_Click">
						<Control.Background>
							<LinearGradientBrush
								EndPoint="0.5,1"
								StartPoint="0.5,0">
								<GradientStop
									Color="Black" />
								<GradientStop
									Color="#FF1A1A1A"
									Offset="1" />
							</LinearGradientBrush>
						</Control.Background>
					</Button>
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
					<Button
						Name="buttonJoinDiscord"
						Style="{StaticResource DarkRoundedButtonStyle}"
						Content="Join Discord"
						Width="105"
						Height="20"
						Margin="-170,0,0,5"
						Click="buttonJoinDiscord_Click">
						<Control.Background>
							<LinearGradientBrush
								EndPoint="0.5,1"
								StartPoint="0.5,0">
								<GradientStop
									Color="Black" />
								<GradientStop
									Color="#FF1A1A1A"
									Offset="1" />
							</LinearGradientBrush>
						</Control.Background>
					</Button>
					<Border
						Background="#FF808080"
						Height="1"
						Margin="0,0,0,10" />
				</StackPanel>
			</ScrollViewer>
		</Grid>
	</Border>
</Window>
